#!/usr/bin/env node
const fs = require('fs');
const path = require('path');
const {
  STATE_FILE,
  VALIDATE_TIMEOUT_MS,
  activeChanges,
  appendAudit,
  mutateStateAndAudit,
  projectRootFromHookDir,
  readImplementationScope,
  readJson,
  readRisk,
  spawnWithTimeout,
} = require('./workflow-hook-lib');

const installedProjectDir = projectRootFromHookDir(__dirname);
const projectDir = path.resolve(process.env.CODEX_PROJECT_DIR || process.env.CLAUDE_PROJECT_DIR || installedProjectDir);
const changesDir = path.join(projectDir, 'openspec', 'changes');
const agent = process.env.CODEX_PROJECT_DIR ? 'codex' : 'claude';

function findSpecFiles(directory) {
  if (!fs.existsSync(directory)) return [];
  return fs.readdirSync(directory, { withFileTypes: true }).flatMap((entry) => {
    const entryPath = path.join(directory, entry.name);
    if (entry.isDirectory()) return findSpecFiles(entryPath);
    return entry.isFile() && entry.name === 'spec.md' ? [entryPath] : [];
  });
}

function checkpoint1Failure(change) {
  const changeDir = path.join(changesDir, change);
  const requiredFiles = ['proposal.md', 'design.md', 'tasks.md'];
  const missingFiles = requiredFiles.filter((file) => !fs.existsSync(path.join(changeDir, file)));
  if (findSpecFiles(path.join(changeDir, 'specs')).length === 0) {
    missingFiles.push('specs/**/spec.md');
  }
  if (missingFiles.length > 0) {
    return `missing required OpenSpec artifacts: ${missingFiles.join(', ')}.`;
  }

  const configuredTimeout = Number(process.env.AI_WORKFLOW_VALIDATE_TIMEOUT_MS);
  const timeoutMs = Number.isFinite(configuredTimeout) && configuredTimeout > 0
    ? configuredTimeout
    : VALIDATE_TIMEOUT_MS;
  const validation = spawnWithTimeout('openspec', ['validate', change, '--strict'], timeoutMs, {
    cwd: projectDir,
    encoding: 'utf8',
  });
  appendAudit(projectDir, {
    agent,
    event: 'openspec.validate',
    change,
    command: `openspec validate ${change} --strict`,
    decision: validation.ok ? 'passed' : (validation.reason === 'timeout' ? 'timeout' : 'failed'),
    reason: validation.ok ? undefined : validation.reason,
  });
  if (!validation.ok) {
    return validation.reason === 'timeout'
      ? `openspec validate ${change} --strict timed out after ${timeoutMs}ms.`
      : `openspec validate ${change} --strict failed.`;
  }
  return null;
}

function auditDenied(event, change, command, reason) {
  appendAudit(projectDir, {
    agent,
    event,
    change,
    command,
    decision: 'denied',
    reason,
  });
}

function deny(event, change, command, message, reason = message) {
  auditDenied(event, change, command, reason);
  console.log(message);
  process.exit(0);
}

const input = readJson(0, {});
const prompt = typeof input.prompt === 'string' ? input.prompt.trim() : '';
const selectMatch = prompt.match(/^CHECKPOINT\s+SELECT\s+([A-Za-z0-9][A-Za-z0-9._-]*)$/);
const approveMatch = prompt.match(/^CHECKPOINT\s+APPROVE\s+([123])\s+([A-Za-z0-9][A-Za-z0-9._-]*)$/);
const riskApproveMatch = prompt.match(/^CHECKPOINT\s+APPROVE\s+RISK\s+([A-Za-z0-9][A-Za-z0-9._-]*)$/);
const closeMatch = prompt.match(/^CHECKPOINT\s+CLOSE\s+([A-Za-z0-9][A-Za-z0-9._-]*)$/);
const pauseMatch = prompt.match(/^CHECKPOINT\s+PAUSE\s+([A-Za-z0-9][A-Za-z0-9._-]*)$/);

if (!selectMatch && !approveMatch && !riskApproveMatch && !closeMatch && !pauseMatch) process.exit(0);

const change = selectMatch?.[1] || approveMatch?.[2] || riskApproveMatch?.[1] || closeMatch?.[1] || pauseMatch[1];
const command = prompt;
const event = closeMatch
  ? 'checkpoint.close'
  : (pauseMatch
    ? 'checkpoint.pause'
    : (riskApproveMatch ? 'checkpoint.risk-approve' : (approveMatch ? 'checkpoint.approve' : 'checkpoint.select')));

if (!activeChanges(projectDir).includes(change)) {
  const reason = `active OpenSpec change not found: ${change}`;
  deny(event, change, command, `Workflow checkpoint state was not changed: ${reason}.`, reason);
}

if (approveMatch && Number(approveMatch[1]) === 1) {
  const failure = checkpoint1Failure(change);
  if (failure) {
    deny(
      event,
      change,
      command,
      `Checkpoint ${Number(approveMatch[1])} approval was not recorded for ${change}: ${failure}`,
      failure,
    );
  }
}

const transition = mutateStateAndAudit(projectDir, (state) => {
  const activeChange = typeof state.activeChange === 'string' ? state.activeChange : null;
  const selectsNamedChange = !!(selectMatch || approveMatch || riskApproveMatch);

  const pausingChange = selectsNamedChange && activeChange && activeChange !== change
    ? { name: activeChange, checkpoint: state.changes[activeChange]?.approvedCheckpoint || 0 }
    : null;
  if (pausingChange) {
    delete state.activeChange;
  }

  if (activeChange && activeChange !== change && !selectsNamedChange && !pauseMatch && !closeMatch) {
    return {
      stateChanged: false,
      auditEntry: {
        agent,
        event,
        change,
        command,
        decision: 'denied',
        reason: `${activeChange} is already selected`,
      },
      message: `Workflow checkpoint state was not changed: ${activeChange} is already selected. Close ${activeChange} or use a separate git worktree before selecting ${change}.`,
    };
  }

  if (pauseMatch && activeChange !== change) {
    return {
      stateChanged: false,
      auditEntry: {
        agent,
        event,
        change,
        command,
        decision: 'recorded',
        reason: 'no active selection to pause',
      },
      message: `No active selection to pause for ${change}.`,
    };
  }

  state.changes[change] ||= { approvedCheckpoint: 0 };
  const currentState = state.changes[change];
  const current = Number(currentState.approvedCheckpoint) || 0;
  const riskResult = (approveMatch || riskApproveMatch) ? readRisk(projectDir, change) : null;
  if (riskResult?.error) {
    return {
      stateChanged: false,
      auditEntry: {
        agent,
        event,
        change,
        command,
        decision: 'denied',
        reason: riskResult.error,
      },
      message: `Workflow approval was not recorded for ${change}: ${riskResult.error}`,
    };
  }

  if (riskApproveMatch) {
    if (riskResult.risk.level !== 'L3') {
      const reason = 'CHECKPOINT APPROVE RISK is only valid for L3 changes.';
      return {
        stateChanged: false,
        auditEntry: {
          agent,
          event,
          change,
          command,
          decision: 'denied',
          reason,
        },
        message: `Task-specific risk approval was not recorded for ${change}: ${reason}`,
      };
    }
    if (current < 1 || currentState.riskFingerprint !== riskResult.fingerprint) {
      return {
        stateChanged: false,
        auditEntry: {
          agent,
          event,
          change,
          command,
          decision: 'denied',
          reason: 'Checkpoint 1 approval for the current risk.json is required first.',
        },
        message: `Task-specific risk approval was not recorded for ${change}: Checkpoint 1 approval for the current risk.json is required first.`,
      };
    }
  }

  if (approveMatch) {
    const checkpoint = Number(approveMatch[1]);
    if (checkpoint === 2 && current < 1) {
      return {
        stateChanged: false,
        auditEntry: {
          agent,
          event,
          change,
          command,
          decision: 'denied',
          reason: 'Checkpoint 1 approval is required first.',
        },
        message: `Checkpoint 2 approval was not recorded for ${change}: Checkpoint 1 approval is required first.`,
      };
    }
    const scopeResult = checkpoint >= 2 ? readImplementationScope(projectDir, change) : null;
    if (scopeResult?.error) {
      return {
        stateChanged: false,
        auditEntry: {
          agent,
          event,
          change,
          command,
          decision: 'denied',
          reason: scopeResult.error,
        },
        message: `Checkpoint ${checkpoint} approval was not recorded for ${change}: ${scopeResult.error}`,
      };
    }
    if (checkpoint === 3 && current < 2) {
      return {
        stateChanged: false,
        auditEntry: {
          agent,
          event,
          change,
          command,
          decision: 'denied',
          reason: 'Checkpoint 2 approval is required first.',
        },
        message: `Checkpoint 3 approval was not recorded for ${change}: Checkpoint 2 approval is required first.`,
      };
    }
    if (checkpoint >= 2 && currentState.riskFingerprint !== riskResult.fingerprint) {
      return {
        stateChanged: false,
        auditEntry: {
          agent,
          event,
          change,
          command,
          decision: 'denied',
          reason: 'risk.json changed; Checkpoint 1 re-approval is required.',
        },
        message: `Checkpoint ${checkpoint} approval was not recorded for ${change}: risk.json changed; Checkpoint 1 re-approval is required.`,
      };
    }
    if (checkpoint >= 3 && currentState.implementationScopeFingerprint !== scopeResult.fingerprint) {
      return {
        stateChanged: false,
        auditEntry: {
          agent,
          event,
          change,
          command,
          decision: 'denied',
          reason: 'implementation-scope.json changed; Checkpoint 2 re-approval is required.',
        },
        message: `Checkpoint ${checkpoint} approval was not recorded for ${change}: implementation-scope.json changed; Checkpoint 2 re-approval is required.`,
      };
    }
    if (checkpoint >= 2 && riskResult.risk.level === 'L4') {
      return {
        stateChanged: false,
        auditEntry: {
          agent,
          event,
          change,
          command,
          decision: 'denied',
          reason: 'L4 changes cannot receive implementation authorization.',
        },
        message: `Checkpoint ${checkpoint} approval was not recorded for ${change}: L4 changes cannot receive implementation authorization.`,
      };
    }
    if (
      checkpoint >= 2 &&
      riskResult.risk.level === 'L3' &&
      currentState.riskApproval?.fingerprint !== riskResult.fingerprint
    ) {
      return {
        stateChanged: false,
        auditEntry: {
          agent,
          event,
          change,
          command,
          decision: 'denied',
          reason: `reply with CHECKPOINT APPROVE RISK ${change} first.`,
        },
        message: `Checkpoint ${checkpoint} approval was not recorded for ${change}: reply with CHECKPOINT APPROVE RISK ${change} first.`,
      };
    }
  }

  if (closeMatch) {
    currentState.approvedCheckpoint = 0;
    delete currentState.riskFingerprint;
    delete currentState.riskApproval;
    delete currentState.implementationScopeFingerprint;
    if (state.activeChange === change) delete state.activeChange;
  } else if (pauseMatch) {
    if (state.activeChange === change) delete state.activeChange;
  } else {
    state.activeChange = change;
  }

  if (approveMatch) {
    const checkpoint = Number(approveMatch[1]);
    if (checkpoint === 1 && currentState.riskFingerprint !== riskResult.fingerprint) {
      currentState.approvedCheckpoint = 1;
      delete currentState.riskApproval;
      delete currentState.implementationScopeFingerprint;
    } else {
      currentState.approvedCheckpoint = Math.max(current, checkpoint);
    }
    currentState.riskFingerprint = riskResult.fingerprint;
    if (checkpoint >= 2) {
      currentState.implementationScopeFingerprint = readImplementationScope(projectDir, change).fingerprint;
    }
  }

  if (riskApproveMatch) {
    currentState.riskApproval = {
      approved: true,
      fingerprint: riskResult.fingerprint,
    };
  }

  return {
    stateChanged: true,
    approvedCheckpoint: currentState.approvedCheckpoint,
    pausedChange: pausingChange,
    wasPaused: !!(pauseMatch && activeChange === change),
    auditEntry: {
      agent,
      event,
      change,
      command,
      decision: 'recorded',
    },
  };
});

if (transition.message) {
  console.log(transition.message);
} else if (closeMatch) {
  console.log(`Closed workflow checkpoint state for ${change}. Re-approval is required before future implementation changes.`);
} else if (pauseMatch) {
  if (transition.wasPaused) {
    console.log(`Paused workflow checkpoint state for ${change}. Checkpoint ${transition.approvedCheckpoint} approval is preserved. Reselect with: CHECKPOINT SELECT ${change}`);
  } else {
    console.log(`No active selection to pause for ${change}.`);
  }
} else if (approveMatch) {
  console.log(`Recorded workflow approval for ${change}: Checkpoint ${transition.approvedCheckpoint}.`);
  if (transition.approvedCheckpoint === 1) {
    console.log(`Next step: generate an implementation plan, test plan, and risk notes. Do not run CHECKPOINT APPROVE 2 until these are complete and reviewed.`);
  }
} else if (riskApproveMatch) {
  console.log(`Recorded task-specific risk approval for ${change}.`);
} else {
  console.log(`Selected active OpenSpec change: ${change}.`);
}
if (transition.pausedChange) {
  console.log(`Paused ${transition.pausedChange.name} (Checkpoint ${transition.pausedChange.checkpoint} preserved). Reselect with: CHECKPOINT SELECT ${transition.pausedChange.name}`);
}
if (transition.auditWarning) {
  console.log(`Warning: workflow audit append failed: ${transition.auditWarning}`);
}
