{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CODEX_PROJECT_DIR:-$PWD}/.codex/hooks/superpowers-session-start\"",
            "async": false
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CODEX_PROJECT_DIR:-$PWD}/.codex/hooks/workflow-checkpoint-record\"",
            "async": false
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "apply_patch|exec_command|shell|write_stdin|Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CODEX_PROJECT_DIR:-$PWD}/.codex/hooks/workflow-checkpoint-gate\"",
            "async": false
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CODEX_PROJECT_DIR:-$PWD}/.codex/hooks/workflow-checkpoint-stop\"",
            "async": false
          }
        ]
      }
    ]
  }
}
